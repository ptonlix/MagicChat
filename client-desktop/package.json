{
  "name": "magicchat-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "MagicChat 三平台桌面客户端",
  "author": "MagicChat Contributors",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "check": "pnpm lint && pnpm typecheck && pnpm verify:boundaries",
    "format": "prettier --write",
    "format:check": "prettier --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:build": "node scripts/verify-build.mjs",
    "verify:boundaries": "node scripts/verify-renderer-boundaries.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "pack": "pnpm build && electron-builder --dir --config electron-builder.yml",
    "pack:win": "pnpm build && electron-builder --win nsis --x64 --arm64 --config electron-builder.yml",
    "pack:mac": "pnpm build && ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --mac dmg zip --universal --config electron-builder.yml",
    "pack:linux": "pnpm build && electron-builder --linux AppImage deb --x64 --arm64 --config electron-builder.yml"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@dnd-kit/core": "6.3.1",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@tanstack/react-virtual": "3.13.18",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "electron-log": "5.4.3",
    "electron-updater": "6.8.9",
    "https-proxy-agent": "7.0.6",
    "lucide-react": "1.22.0",
    "next-themes": "0.4.6",
    "pinyin-pro": "3.28.1",
    "radix-ui": "1.6.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "react-day-picker": "10.0.1",
    "react-router": "8.1.0",
    "recharts": "3.8.0",
    "remark-flexible-markers": "1.3.5",
    "remark-gfm": "4.0.1",
    "remark-supersub": "1.0.0",
    "shiki": "4.3.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "harmonyos-sans-sc-webfont-splitted": "1.1.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "shadcn": "4.12.0",
    "tailwindcss": "4.2.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.65.0",
    "vite": "8.0.1",
    "vitest": "4.1.9"
  }
}
