IMAGE_REGISTRY=ghcr.1ms.run/chaitin/magicchat
IMAGE_TAG=latest

PUBLIC_HOSTNAME=localhost
CLIENT_HTTPS_PORT=443
ADMIN_HTTPS_PORT=1443
PUBLIC_ASSETS_HOSTNAME=public-assets.localhost
PRIVATE_ASSETS_HOSTNAME=private-assets.localhost
TEMPORARY_ASSETS_HOSTNAME=temporary-assets.localhost

POSTGRES_DB=magic-chat
POSTGRES_USER=magic-chat
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
ADMIN_PASSWORD=change-me
AI_ASSISTANT_SECRET=change-me

ASSISTANT_WEBSOCKET_URL=ws://server:20080/api/app/ws
AGENT_MAX_TURNS=50
AGENT_MAX_SESSIONS=1000
LLM_BASE_URL=https://api.example.com
LLM_API_KEY=change-me
LLM_MODEL_NAME=change-me
MCP_GATEWAY_URL=https://mcp.example.com/mcp
MCP_GATEWAY_KEY=change-me

AWS_ENDPOINT_URL_S3=https://s3.example.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
S3_BOOTSTRAP_ENABLED=false
S3_FORCE_PATH_STYLE=false
PUBLIC_ASSETS_BUCKET=magicchat-public
PRIVATE_ASSETS_BUCKET=magicchat-private
TEMPORARY_ASSETS_BUCKET=magicchat-temporary
TEMPORARY_ASSETS_EXPIRE_DAYS=180
S3_ABORT_MULTIPART_DAYS=7
